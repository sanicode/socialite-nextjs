generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model addresses {
  id             BigInt    @id @default(autoincrement())
  user_id        BigInt?
  address_line_1 String?   @db.VarChar(255)
  address_line_2 String?   @db.VarChar(255)
  city           String?   @db.VarChar(255)
  state          String?   @db.VarChar(255)
  zip            String?   @db.VarChar(255)
  country_code   String?   @db.VarChar(255)
  phone          String?   @db.VarChar(255)
  tax_number     String?   @db.VarChar(255)
  created_at     DateTime? @db.Timestamp(0)
  updated_at     DateTime? @db.Timestamp(0)
  tenant_id      BigInt?
  province_id    Int?
  city_id        Int?
  users          users?    @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "addresses_user_id_foreign")
}

model announcements {
  id                     BigInt    @id @default(autoincrement())
  title                  String    @db.VarChar(255)
  content                String
  starts_at              DateTime? @db.Timestamp(0)
  ends_at                DateTime? @db.Timestamp(0)
  is_active              Boolean   @default(true)
  is_dismissible         Boolean   @default(true)
  show_for_customers     Boolean   @default(true)
  show_on_frontend       Boolean   @default(true)
  show_on_user_dashboard Boolean   @default(true)
  created_at             DateTime? @db.Timestamp(0)
  updated_at             DateTime? @db.Timestamp(0)
}

model blog_post_categories {
  id         BigInt       @id @default(autoincrement())
  name       String       @db.VarChar(255)
  slug       String       @unique(map: "blog_post_categories_slug_unique") @db.VarChar(255)
  created_at DateTime?    @db.Timestamp(0)
  updated_at DateTime?    @db.Timestamp(0)
  deleted_at DateTime?    @db.Timestamp(0)
  blog_posts blog_posts[]
}

/// This model contains an expression index which requires additional setup for migrations. Visit https://pris.ly/d/expression-indexes for more info.
model blog_posts {
  id                                BigInt                @id @default(autoincrement())
  title                             String?
  slug                              String?               @unique(map: "blog_posts_slug_unique") @db.VarChar(255)
  body                              String?
  is_published                      Boolean               @default(false)
  published_at                      DateTime?             @db.Timestamp(0)
  user_id                           BigInt
  author_id                         BigInt?
  blog_post_category_id             BigInt?
  description                       String?
  status                            String?               @default("pending") @db.VarChar(20)
  created_at                        DateTime?             @db.Timestamp(0)
  updated_at                        DateTime?             @db.Timestamp(0)
  tenant_id                         BigInt?
  deleted_at                        DateTime?             @db.Timestamp(0)
  social_otp_id                     BigInt?
  source_url                        String?
  users_blog_posts_author_idTousers users?                @relation("blog_posts_author_idTousers", fields: [author_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "blog_posts_author_id_foreign")
  blog_post_categories              blog_post_categories? @relation(fields: [blog_post_category_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "blog_posts_blog_post_category_id_foreign")
  social_otps                       social_otps?          @relation(fields: [social_otp_id], references: [id], map: "blog_posts_telegram_social_otp_id_foreign")
  tenants                           tenants?              @relation(fields: [tenant_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "blog_posts_tenant_id_foreign")
  users_blog_posts_user_idTousers   users                 @relation("blog_posts_user_idTousers", fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "blog_posts_user_id_foreign")
}

model configs {
  id         BigInt    @id @default(autoincrement())
  key        String    @unique(map: "configs_key_unique") @db.VarChar(255)
  value      String?
  created_at DateTime? @db.Timestamp(0)
  updated_at DateTime? @db.Timestamp(0)
}

model currencies {
  id                      BigInt                    @id @default(autoincrement())
  name                    String                    @unique(map: "currencies_name_unique") @db.VarChar(255)
  code                    String                    @unique(map: "currencies_code_unique") @db.VarChar(255)
  symbol                  String?                   @db.VarChar(255)
  created_at              DateTime?                 @db.Timestamp(0)
  updated_at              DateTime?                 @db.Timestamp(0)
  one_time_product_prices one_time_product_prices[]
  order_items             order_items[]
  orders                  orders[]
  plan_prices             plan_prices[]
  subscriptions           subscriptions[]
  transactions            transactions[]
}

model discount_code_redemptions {
  id               BigInt         @id @default(autoincrement())
  discount_code_id BigInt
  user_id          BigInt
  subscription_id  BigInt?
  order_id         BigInt?
  created_at       DateTime?      @db.Timestamp(0)
  updated_at       DateTime?      @db.Timestamp(0)
  discount_codes   discount_codes @relation(fields: [discount_code_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "discount_code_redemptions_discount_code_id_foreign")
  orders           orders?        @relation(fields: [order_id], references: [id], onUpdate: NoAction, map: "discount_code_redemptions_order_id_foreign")
  subscriptions    subscriptions? @relation(fields: [subscription_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "discount_code_redemptions_subscription_id_foreign")
  users            users          @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "discount_code_redemptions_user_id_foreign")
}

model discount_codes {
  id                                                                   BigInt                      @id @default(autoincrement())
  code                                                                 String                      @unique(map: "discount_codes_code_unique") @db.VarChar(255)
  discount_id                                                          BigInt
  created_at                                                           DateTime?                   @db.Timestamp(0)
  updated_at                                                           DateTime?                   @db.Timestamp(0)
  referral_reward_id                                                   BigInt?
  is_referral_reward                                                   Boolean                     @default(false)
  discount_code_redemptions                                            discount_code_redemptions[]
  discounts                                                            discounts                   @relation(fields: [discount_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "discount_codes_discount_id_foreign")
  referral_rewards_discount_codes_referral_reward_idToreferral_rewards referral_rewards?           @relation("discount_codes_referral_reward_idToreferral_rewards", fields: [referral_reward_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "discount_codes_referral_reward_id_foreign")
  referral_rewards_referral_rewards_discount_code_idTodiscount_codes   referral_rewards[]          @relation("referral_rewards_discount_code_idTodiscount_codes")
}

model discount_one_time_product {
  id                  BigInt            @id @default(autoincrement())
  discount_id         BigInt
  one_time_product_id BigInt
  created_at          DateTime?         @db.Timestamp(0)
  updated_at          DateTime?         @db.Timestamp(0)
  discounts           discounts         @relation(fields: [discount_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "discount_one_time_product_discount_id_foreign")
  one_time_products   one_time_products @relation(fields: [one_time_product_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "discount_one_time_product_one_time_product_id_foreign")
}

model discount_payment_provider_data {
  id                           BigInt            @id @default(autoincrement())
  discount_id                  BigInt
  payment_provider_id          BigInt
  payment_provider_discount_id String            @db.VarChar(255)
  created_at                   DateTime?         @db.Timestamp(0)
  updated_at                   DateTime?         @db.Timestamp(0)
  discounts                    discounts         @relation(fields: [discount_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "discount_payment_provider_data_discount_id_foreign")
  payment_providers            payment_providers @relation(fields: [payment_provider_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "discount_payment_provider_data_payment_provider_id_foreign")
}

model discount_plan {
  id          BigInt    @id @default(autoincrement())
  discount_id BigInt
  plan_id     BigInt
  created_at  DateTime? @db.Timestamp(0)
  updated_at  DateTime? @db.Timestamp(0)
  discounts   discounts @relation(fields: [discount_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "discount_plan_discount_id_foreign")
  plans       plans     @relation(fields: [plan_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "discount_plan_plan_id_foreign")
}

model discounts {
  id                                   BigInt                           @id @default(autoincrement())
  name                                 String                           @db.VarChar(255)
  description                          String?                          @db.VarChar(255)
  type                                 String                           @db.VarChar(255)
  amount                               Float
  valid_until                          DateTime?                        @db.Timestamp(0)
  is_active                            Boolean                          @default(true)
  action_type                          String?                          @db.VarChar(255)
  max_redemptions                      Int?
  max_redemptions_per_user             Int?
  redemptions                          Int                              @default(0)
  is_recurring                         Boolean                          @default(false)
  duration_in_months                   Int?
  maximum_recurring_intervals          Int?
  created_at                           DateTime?                        @db.Timestamp(0)
  updated_at                           DateTime?                        @db.Timestamp(0)
  is_enabled_for_all_plans             Boolean                          @default(false)
  is_enabled_for_all_one_time_products Boolean                          @default(false)
  discount_codes                       discount_codes[]
  discount_one_time_product            discount_one_time_product[]
  discount_payment_provider_data       discount_payment_provider_data[]
  discount_plan                        discount_plan[]
  order_discounts                      order_discounts[]
  subscription_discounts               subscription_discounts[]
}

model email_providers {
  id         BigInt    @id @default(autoincrement())
  name       String    @db.VarChar(255)
  slug       String    @unique(map: "email_providers_slug_unique") @db.VarChar(255)
  created_at DateTime? @db.Timestamp(0)
  updated_at DateTime? @db.Timestamp(0)
}

model failed_jobs {
  id         BigInt   @id @default(autoincrement())
  uuid       String   @unique(map: "failed_jobs_uuid_unique") @db.VarChar(255)
  connection String
  queue      String
  payload    String
  exception  String
  failed_at  DateTime @default(now()) @db.Timestamp(0)
}

model intervals {
  id                                       BigInt          @id @default(autoincrement())
  name                                     String          @db.VarChar(255)
  slug                                     String          @unique(map: "intervals_slug_unique") @db.VarChar(255)
  date_identifier                          String          @db.VarChar(255)
  adverb                                   String?         @db.VarChar(255)
  created_at                               DateTime?       @db.Timestamp(0)
  updated_at                               DateTime?       @db.Timestamp(0)
  plans_plans_interval_idTointervals       plans[]         @relation("plans_interval_idTointervals")
  plans_plans_trial_interval_idTointervals plans[]         @relation("plans_trial_interval_idTointervals")
  subscriptions                            subscriptions[]
}

model invoices {
  id             BigInt       @id @default(autoincrement())
  uuid           String       @unique(map: "invoices_uuid_unique") @db.Uuid
  transaction_id BigInt
  status         String       @default("unrendered") @db.VarChar(255)
  filename       String?      @db.VarChar(255)
  created_at     DateTime?    @db.Timestamp(0)
  updated_at     DateTime?    @db.Timestamp(0)
  transactions   transactions @relation(fields: [transaction_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "invoices_transaction_id_foreign")
}

model media {
  id                    BigInt    @id @default(autoincrement())
  model_type            String    @db.VarChar(255)
  model_id              BigInt
  uuid                  String?   @unique(map: "media_uuid_unique") @db.Uuid
  collection_name       String    @db.VarChar(255)
  name                  String    @db.VarChar(255)
  file_name             String    @db.VarChar(255)
  mime_type             String?   @db.VarChar(255)
  disk                  String    @db.VarChar(255)
  conversions_disk      String?   @db.VarChar(255)
  size                  BigInt
  manipulations         Json      @db.Json
  custom_properties     Json      @db.Json
  generated_conversions Json      @db.Json
  responsive_images     Json      @db.Json
  order_column          Int?
  created_at            DateTime? @db.Timestamp(0)
  updated_at            DateTime? @db.Timestamp(0)

  @@index([model_type, model_id], map: "media_model_type_model_id_index")
  @@index([order_column], map: "media_order_column_index")
}

model metric_data {
  id         BigInt   @id @default(autoincrement())
  metric_id  BigInt
  value      Decimal  @db.Decimal(15, 2)
  created_at DateTime @db.Timestamp(0)
  metrics    metrics  @relation(fields: [metric_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "metric_data_metric_id_foreign")

  @@index([created_at], map: "metric_data_created_at_index")
}

model metrics {
  id          BigInt        @id @default(autoincrement())
  name        String        @unique(map: "metrics_name_unique") @db.VarChar(255)
  created_at  DateTime?     @db.Timestamp(0)
  updated_at  DateTime?     @db.Timestamp(0)
  metric_data metric_data[]
}

model migrations {
  id          Int     @id @default(autoincrement())
  migration   String  @db.VarChar(255)
  batch       Int
  filament_cd String? @db.VarChar(255)

  @@index([filament_cd], map: "migrations_filament_cd_index")
}

model model_has_permissions {
  permission_id BigInt
  model_type    String      @db.VarChar(255)
  model_id      BigInt
  permissions   permissions @relation(fields: [permission_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "model_has_permissions_permission_id_foreign")

  @@id([permission_id, model_id, model_type])
  @@index([model_id, model_type], map: "model_has_permissions_model_id_model_type_index")
}

model model_has_roles {
  role_id    BigInt
  model_type String @db.VarChar(255)
  model_id   BigInt
  roles      roles  @relation(fields: [role_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "model_has_roles_role_id_foreign")

  @@id([role_id, model_id, model_type])
  @@index([model_id, model_type], map: "model_has_roles_model_id_model_type_index")
}

model oauth_login_providers {
  id            BigInt    @id @default(autoincrement())
  name          String    @db.VarChar(255)
  provider_name String    @unique(map: "oauth_login_providers_provider_name_unique") @db.VarChar(255)
  enabled       Boolean   @default(false)
  created_at    DateTime? @db.Timestamp(0)
  updated_at    DateTime? @db.Timestamp(0)
}

model one_time_passwords {
  id                   BigInt    @id @default(autoincrement())
  password             String    @db.VarChar(255)
  origin_properties    Json?     @db.Json
  expires_at           DateTime  @db.Timestamp(0)
  authenticatable_type String    @db.VarChar(255)
  authenticatable_id   BigInt
  created_at           DateTime? @db.Timestamp(0)
  updated_at           DateTime? @db.Timestamp(0)

  @@index([authenticatable_type, authenticatable_id], map: "one_time_passwords_authenticatable_type_authenticatable_id_inde")
}

model one_time_product_payment_provider_data {
  id                          BigInt            @id @default(autoincrement())
  one_time_product_id         BigInt
  payment_provider_id         BigInt
  payment_provider_product_id String?           @db.VarChar(255)
  created_at                  DateTime?         @db.Timestamp(0)
  updated_at                  DateTime?         @db.Timestamp(0)
  one_time_products           one_time_products @relation(fields: [one_time_product_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "one_time_product_payment_264vc5")
  payment_providers           payment_providers @relation(fields: [payment_provider_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "one_time_product_payment_264vc6")

  @@unique([one_time_product_id, payment_provider_id], map: "pro_payment_provider_data_unq")
}

model one_time_product_price_payment_provider_data {
  id                        BigInt                  @id @default(autoincrement())
  one_time_product_price_id BigInt
  payment_provider_id       BigInt
  payment_provider_price_id String?                 @db.VarChar(255)
  created_at                DateTime?               @db.Timestamp(0)
  updated_at                DateTime?               @db.Timestamp(0)
  one_time_product_prices   one_time_product_prices @relation(fields: [one_time_product_price_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "one_time_product_payment_264vc7")
  payment_providers         payment_providers       @relation(fields: [payment_provider_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "one_time_product_payment_264vc8")

  @@unique([one_time_product_price_id, payment_provider_id], map: "pro_price_payment_provider_data_unq")
}

model one_time_product_prices {
  id                                           BigInt                                         @id @default(autoincrement())
  one_time_product_id                          BigInt
  currency_id                                  BigInt
  price                                        Int
  created_at                                   DateTime?                                      @db.Timestamp(0)
  updated_at                                   DateTime?                                      @db.Timestamp(0)
  one_time_product_price_payment_provider_data one_time_product_price_payment_provider_data[]
  currencies                                   currencies                                     @relation(fields: [currency_id], references: [id], onDelete: Cascade, map: "one_time_product_prices_currency_id_foreign")
  one_time_products                            one_time_products                              @relation(fields: [one_time_product_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "one_time_product_prices_one_time_product_id_foreign")
}

model one_time_products {
  id                                     BigInt                                   @id @default(autoincrement())
  name                                   String                                   @db.VarChar(255)
  slug                                   String                                   @unique(map: "one_time_products_slug_unique") @db.VarChar(255)
  description                            String?                                  @db.VarChar(255)
  max_quantity                           String                                   @default("1") @db.VarChar(255)
  metadata                               Json?                                    @db.Json
  features                               Json?                                    @db.Json
  is_active                              Boolean                                  @default(true)
  created_at                             DateTime?                                @db.Timestamp(0)
  updated_at                             DateTime?                                @db.Timestamp(0)
  is_visible                             Boolean                                  @default(true)
  discount_one_time_product              discount_one_time_product[]
  one_time_product_payment_provider_data one_time_product_payment_provider_data[]
  one_time_product_prices                one_time_product_prices[]
  order_items                            order_items[]
}

model order_discounts {
  id          BigInt    @id @default(autoincrement())
  discount_id BigInt
  order_id    BigInt
  type        String    @db.VarChar(255)
  amount      Float
  valid_until DateTime? @db.Timestamp(0)
  created_at  DateTime? @db.Timestamp(0)
  updated_at  DateTime? @db.Timestamp(0)
  discounts   discounts @relation(fields: [discount_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "order_discounts_discount_id_foreign")
  orders      orders    @relation(fields: [order_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "order_discounts_order_id_foreign")
}

model order_items {
  id                            BigInt            @id @default(autoincrement())
  order_id                      BigInt
  one_time_product_id           BigInt
  quantity                      Int
  currency_id                   BigInt?
  price_per_unit                Int
  price_per_unit_after_discount Int               @default(0)
  discount_per_unit             Int               @default(0)
  created_at                    DateTime?         @db.Timestamp(0)
  updated_at                    DateTime?         @db.Timestamp(0)
  currencies                    currencies?       @relation(fields: [currency_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "order_items_currency_id_foreign")
  one_time_products             one_time_products @relation(fields: [one_time_product_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "order_items_one_time_product_id_foreign")
  orders                        orders            @relation(fields: [order_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "order_items_order_id_foreign")
}

model orders {
  id                          BigInt                      @id @default(autoincrement())
  uuid                        String                      @unique(map: "orders_uuid_unique") @db.Uuid
  user_id                     BigInt?
  status                      String                      @db.VarChar(255)
  currency_id                 BigInt?
  total_amount                BigInt                      @default(0)
  total_amount_after_discount BigInt                      @default(0)
  total_discount_amount       BigInt                      @default(0)
  payment_provider_order_id   String?                     @db.VarChar(255)
  payment_provider_id         BigInt?
  created_at                  DateTime?                   @db.Timestamp(0)
  updated_at                  DateTime?                   @db.Timestamp(0)
  tenant_id                   BigInt
  is_local                    Boolean                     @default(false)
  comments                    String?
  discount_code_redemptions   discount_code_redemptions[]
  order_discounts             order_discounts[]
  order_items                 order_items[]
  currencies                  currencies?                 @relation(fields: [currency_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "orders_currency_id_foreign")
  payment_providers           payment_providers?          @relation(fields: [payment_provider_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "orders_payment_provider_id_foreign")
  tenants                     tenants                     @relation(fields: [tenant_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "orders_tenant_id_foreign")
  users                       users?                      @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "orders_user_id_foreign")
  transactions                transactions[]
}

model password_reset_tokens {
  email      String    @id @db.VarChar(255)
  token      String    @db.VarChar(255)
  created_at DateTime? @db.Timestamp(0)
}

/// The underlying table does not contain a valid unique identifier and can therefore currently not be handled by Prisma Client.
model password_resets {
  email      String    @db.VarChar(255)
  token      String    @db.VarChar(255)
  created_at DateTime? @db.Timestamp(0)

  @@index([email], map: "password_resets_email_index")
  @@ignore
}

model payment_providers {
  id                                           BigInt                                         @id @default(autoincrement())
  created_at                                   DateTime?                                      @db.Timestamp(0)
  updated_at                                   DateTime?                                      @db.Timestamp(0)
  type                                         String                                         @db.VarChar(255)
  name                                         String                                         @db.VarChar(255)
  slug                                         String                                         @unique(map: "payment_providers_slug_unique") @db.VarChar(255)
  is_active                                    Boolean                                        @default(true)
  sort                                         Int                                            @default(0)
  is_enabled_for_new_payments                  Boolean                                        @default(true)
  discount_payment_provider_data               discount_payment_provider_data[]
  one_time_product_payment_provider_data       one_time_product_payment_provider_data[]
  one_time_product_price_payment_provider_data one_time_product_price_payment_provider_data[]
  orders                                       orders[]
  plan_meter_payment_provider_data             plan_meter_payment_provider_data[]
  plan_payment_provider_data                   plan_payment_provider_data[]
  plan_price_payment_provider_data             plan_price_payment_provider_data[]
  subscriptions                                subscriptions[]
  transactions                                 transactions[]
}

model permissions {
  id                    BigInt                  @id @default(autoincrement())
  name                  String                  @db.VarChar(255)
  guard_name            String                  @db.VarChar(255)
  created_at            DateTime?               @db.Timestamp(0)
  updated_at            DateTime?               @db.Timestamp(0)
  is_tenant_permission  Boolean                 @default(false)
  model_has_permissions model_has_permissions[]
  role_has_permissions  role_has_permissions[]

  @@unique([name, guard_name], map: "permissions_name_guard_name_unique")
}

model personal_access_tokens {
  id             BigInt    @id @default(autoincrement())
  tokenable_type String    @db.VarChar(255)
  tokenable_id   BigInt
  name           String    @db.VarChar(255)
  token          String    @unique(map: "personal_access_tokens_token_unique") @db.VarChar(64)
  abilities      String?
  last_used_at   DateTime? @db.Timestamp(0)
  expires_at     DateTime? @db.Timestamp(0)
  created_at     DateTime? @db.Timestamp(0)
  updated_at     DateTime? @db.Timestamp(0)

  @@index([tokenable_type, tokenable_id], map: "personal_access_tokens_tokenable_type_tokenable_id_index")
}

